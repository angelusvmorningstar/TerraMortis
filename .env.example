# MongoDB Atlas connection string
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/tm_suite

# Server port
PORT=3000

# Environment
NODE_ENV=development

# Allowed CORS origins (comma-separated)
CORS_ORIGIN=http://localhost:8080,http://localhost:3000

# Discord OAuth2 (from https://discord.com/developers/applications)
DISCORD_CLIENT_ID=<your_client_id>
DISCORD_CLIENT_SECRET=<your_client_secret>
DISCORD_REDIRECT_URI=http://localhost:8080/admin

# Storyteller Discord IDs (comma-separated)
ST_IDS=<discord_id_1>,<discord_id_2>,<discord_id_3>
